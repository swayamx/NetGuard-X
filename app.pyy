def classify_attack(row):
    if row["size"] > 1400 and row["proto"] == 1:
        return "DDoS Attack"

    if row["size"] < 100 and row["proto"] > 10:
        return "Port Scanning"

    if row["size"] > 1000 and row["proto"] > 5:
        return "Data Exfiltration"

    return "Unknown Threat"

